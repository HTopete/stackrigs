---
import { detectLocaleFromPath, useTranslations } from '../i18n/index';

interface Props {
  lastUpdated: string;
}

const { lastUpdated } = Astro.props;
const locale = detectLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);

// Labels for client-side script (avoids hydration mismatch)
const labels = {
  active: t('freshness.active'),
  semiActive: t('freshness.semiActive'),
  archived: t('freshness.archived'),
  updated: t('common.updated'),
  dayAgo: t('common.dayAgo'),
  daysAgo: t('common.daysAgo'),
};
---

<span
  class="freshness-indicator"
  data-last-updated={lastUpdated}
  data-labels={JSON.stringify(labels)}
>
  <span class="freshness-dot freshness-unknown" aria-hidden="true"></span>
  <span class="freshness-label font-mono"></span>
</span>

<script>
  function initFreshness(el: HTMLElement) {
    const raw = el.dataset.lastUpdated;
    const labels = JSON.parse(el.dataset.labels || '{}');
    if (!raw) return;

    const diffDays = Math.floor((Date.now() - new Date(raw).getTime()) / 86_400_000);
    const dot = el.querySelector('.freshness-dot') as HTMLElement;
    const label = el.querySelector('.freshness-label') as HTMLElement;

    let cls: string;
    let text: string;
    if (diffDays < 30) {
      cls = 'freshness-active'; text = labels.active;
    } else if (diffDays < 90) {
      cls = 'freshness-semi-active'; text = labels.semiActive;
    } else {
      cls = 'freshness-archived'; text = labels.archived;
    }

    dot.className = `freshness-dot ${cls}`;
    label.textContent = text;
    const ago = `${labels.updated} ${diffDays} ${diffDays === 1 ? labels.dayAgo : labels.daysAgo}`;
    el.setAttribute('title', ago);
    el.setAttribute('aria-label', `${text}: ${ago}`);
  }

  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll<HTMLElement>('.freshness-indicator[data-last-updated]').forEach(initFreshness);
  });
</script>

<style>
  .freshness-indicator {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    cursor: default;
  }

  .freshness-label {
    font-family: var(--font-mono);
  }

  /* Unknown state before JS runs — invisible dot, no label */
  .freshness-unknown {
    opacity: 0;
  }
</style>
