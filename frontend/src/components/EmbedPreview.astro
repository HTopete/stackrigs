---
import { detectLocaleFromPath, useTranslations } from '../i18n/index';

interface Props {
  handle: string;
  buildId: string;
}

const { handle, buildId } = Astro.props;
const locale = detectLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);

const badgeUrl = `https://api.stackrigs.com/badge/${handle}.svg`;
const embedCode = `<img src="${badgeUrl}" alt="StackRigs build badge for ${handle}" />`;
---

<section class="embed-box" aria-label={t('embed.preview')}>
  <h3>{t('embed.preview')}</h3>

  <div class="embed-preview-img">
    <img src={badgeUrl} alt={`StackRigs build badge for ${handle}`} loading="lazy" />
  </div>

  <div class="embed-code">
    <code>{embedCode}</code>
    <button
      type="button"
      class="btn btn-ghost"
      aria-label={t('embed.copyCode')}
      data-embed-copy
      data-code={embedCode}
    >
      {t('embed.copyCode')}
    </button>
  </div>

  <p class="embed-hint text-muted">
    {t('embed.addToReadme')}
  </p>
</section>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll<HTMLButtonElement>('[data-embed-copy]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const code = btn.dataset.code;
        if (!code) return;
        try {
          await navigator.clipboard.writeText(code);
          const original = btn.textContent;
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = original; }, 2000);
        } catch {
          // Fallback: select text
        }
      });
    });
  });
</script>

<style>
  .embed-preview-img {
    margin-top: var(--space-4);
    padding: var(--space-4);
    background: var(--color-bg);
    border-radius: var(--radius-sm);
    display: flex;
    justify-content: center;
  }

  .embed-preview-img img {
    max-height: 60px;
  }

  .embed-hint {
    margin-top: var(--space-3);
    font-size: var(--font-size-sm);
  }
</style>
