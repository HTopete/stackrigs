---
import Page from '../layouts/Page.astro';
import ExploreIsland from '../islands/ExploreIsland';
import { detectLocaleFromPath, useTranslations } from '../i18n/index';
import { getBuilds, getTechnologies } from '../lib/api';

const locale = detectLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);

const { builds, total } = await getBuilds({ limit: 20, sort: 'updated' });
const allTechs = await getTechnologies();
const techs = allTechs.filter(t => t.count > 0).sort((a, b) => b.count - a.count);

const exploreLabels = {
  technology: t('explore.technology'),
  status: t('explore.status'),
  sortBy: t('explore.sortBy'),
  sortUpdated: t('explore.sortUpdated'),
  sortCreated: t('explore.sortCreated'),
  noBuilds: t('explore.noBuilds'),
  clearFilters: t('explore.clearFilters'),
  showMore: t('common.showMore'),
  showLess: t('common.showLess'),
  results: t('explore.results'),
  statusLabels: {
    building: t('buildLog.status.building'),
    launched: t('buildLog.status.launched'),
    paused: t('buildLog.status.paused'),
    abandoned: t('buildLog.status.abandoned'),
  },
};
---

<Page
  title={`${t('explore.title')} — StackRigs`}
  description="Browse real build logs from developers around the world. Filter by technology, status, and more."
>
  <section class="page-section">
    <h1>{t('explore.title')}</h1>
    <div style="margin-top: var(--space-8);">
      <ExploreIsland
        client:visible
        initialBuilds={builds}
        initialTotal={total}
        technologies={techs}
        locale={locale}
        labels={exploreLabels}
      />
    </div>
  </section>
</Page>
