---
import Page from '../layouts/Page.astro';
import BuildCard from '../components/BuildCard.astro';
import { detectLocaleFromPath, useTranslations, localePath } from '../i18n/index';

const locale = detectLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);

// Mock data — replace with API call
const builds = [
  {
    id: '1',
    name: 'StackRigs',
    tagline: 'An open index of what developers build',
    status: 'building' as const,
    stack: [
      { slug: 'go', displayName: 'Go' },
      { slug: 'astro', displayName: 'Astro' },
      { slug: 'sqlite', displayName: 'SQLite' },
    ],
    whatWorks: 'SQLite on a Pi 5 handles 500+ req/s without breaking a sweat.',
    lastUpdated: '2026-03-01',
  },
  {
    id: '2',
    name: 'DataForge',
    tagline: 'ETL pipelines for small teams',
    status: 'launched' as const,
    stack: [
      { slug: 'python', displayName: 'Python' },
      { slug: 'postgresql', displayName: 'PostgreSQL' },
    ],
    whatWorks: 'PostgreSQL logical replication is rock solid for CDC.',
    lastUpdated: '2026-02-15',
  },
  {
    id: '3',
    name: 'Noteship',
    tagline: 'Offline-first notes with sync',
    status: 'building' as const,
    stack: [
      { slug: 'react', displayName: 'React' },
      { slug: 'crdts', displayName: 'CRDTs' },
    ],
    lastUpdated: '2026-02-28',
  },
];

const technologies = ['Go', 'React', 'Python', 'Rust', 'TypeScript', 'Astro'];
const statuses = ['building', 'launched', 'paused', 'abandoned'];
const currentPage = 1;
const totalPages = 5;
---

<Page
  title={`${t('explore.title')} — StackRigs`}
  description="Browse real build logs from developers around the world. Filter by technology, status, and more."
>
  <section class="page-section">
    <h1>{t('explore.title')}</h1>

    <div class="explore-layout" style="margin-top: var(--space-8);">
      <!-- Filters Sidebar -->
      <aside class="filters" aria-label={t('explore.filterBy')}>
        <div class="filter-group">
          <h3 class="filter-group-title">{t('explore.technology')}</h3>
          {technologies.map(tech => (
            <label class="filter-option">
              <input type="checkbox" name="tech" value={tech.toLowerCase()} />
              {tech}
            </label>
          ))}
        </div>

        <div class="filter-group">
          <h3 class="filter-group-title">{t('explore.status')}</h3>
          {statuses.map(status => (
            <label class="filter-option">
              <input type="checkbox" name="status" value={status} />
              {t(`buildLog.status.${status}`)}
            </label>
          ))}
        </div>

        <div class="filter-group">
          <h3 class="filter-group-title">{t('explore.sortBy')}</h3>
          <label class="filter-option">
            <input type="radio" name="sort" value="updated" checked />
            {t('explore.sortUpdated')}
          </label>
          <label class="filter-option">
            <input type="radio" name="sort" value="created" />
            {t('explore.sortCreated')}
          </label>
        </div>
      </aside>

      <!-- Build Grid -->
      <div>
        <div class="grid-cards">
          {builds.map(build => (
            <BuildCard build={build} />
          ))}
        </div>

        <!-- Pagination -->
        <nav class="pagination" aria-label="Pagination">
          {currentPage > 1 && (
            <a href={`?page=${currentPage - 1}`} class="btn btn-ghost" aria-label={t('explore.prev')}>
              &larr; {t('explore.prev')}
            </a>
          )}
          {Array.from({ length: totalPages }, (_, i) => i + 1).map(page => (
            <a
              href={`?page=${page}`}
              class="pagination-page"
              aria-current={page === currentPage ? 'page' : undefined}
              aria-label={`Page ${page}`}
            >
              {page}
            </a>
          ))}
          {currentPage < totalPages && (
            <a href={`?page=${currentPage + 1}`} class="btn btn-ghost" aria-label={t('explore.next')}>
              {t('explore.next')} &rarr;
            </a>
          )}
        </nav>
      </div>
    </div>
  </section>
</Page>
