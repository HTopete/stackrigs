---
import Page from '../layouts/Page.astro';
import BuildCard from '../components/BuildCard.astro';
import { detectLocaleFromPath, useTranslations, localePath } from '../i18n/index';
import { getBuilds, getTechnologies } from '../lib/api';

const locale = detectLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);

const { builds } = await getBuilds({ limit: 20, sort: 'updated' });
const techs = await getTechnologies();
const technologies = techs.map(t => t.displayName);
const statuses = ['building', 'launched', 'paused', 'abandoned'];
---

<Page
  title={`${t('explore.title')} — StackRigs`}
  description="Browse real build logs from developers around the world. Filter by technology, status, and more."
>
  <section class="page-section">
    <h1>{t('explore.title')}</h1>

    <div class="explore-layout" style="margin-top: var(--space-8);">
      <!-- Filters Sidebar -->
      <aside class="filters" aria-label={t('explore.filterBy')}>
        <div class="filter-group">
          <h3 class="filter-group-title">{t('explore.technology')}</h3>
          {technologies.map(tech => (
            <label class="filter-option">
              <input type="checkbox" name="tech" value={tech.toLowerCase()} />
              {tech}
            </label>
          ))}
        </div>

        <div class="filter-group">
          <h3 class="filter-group-title">{t('explore.status')}</h3>
          {statuses.map(status => (
            <label class="filter-option">
              <input type="checkbox" name="status" value={status} />
              {t(`buildLog.status.${status}`)}
            </label>
          ))}
        </div>

        <div class="filter-group">
          <h3 class="filter-group-title">{t('explore.sortBy')}</h3>
          <label class="filter-option">
            <input type="radio" name="sort" value="updated" checked />
            {t('explore.sortUpdated')}
          </label>
          <label class="filter-option">
            <input type="radio" name="sort" value="created" />
            {t('explore.sortCreated')}
          </label>
        </div>
      </aside>

      <!-- Build Grid -->
      <div>
        <div class="grid-cards">
          {builds.map(build => (
            <BuildCard build={build} />
          ))}
        </div>

        {builds.length === 0 && (
          <p class="text-muted" style="text-align: center; padding: var(--space-8);">
            {t('explore.noBuilds')}
          </p>
        )}
      </div>
    </div>
  </section>
</Page>
