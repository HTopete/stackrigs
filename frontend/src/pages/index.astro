---
import Page from '../layouts/Page.astro';
import BuildCard from '../components/BuildCard.astro';
import StackTag from '../components/StackTag.astro';
import { detectLocaleFromPath, useTranslations, localePath } from '../i18n/index';
import { getBuilds, getTechnologies } from '../lib/api';

const locale = detectLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);

const { builds: recentBuilds } = await getBuilds({ limit: 6, sort: 'updated' });
const allStacks = await getTechnologies();
const popularStacks = allStacks
  .filter(s => s.count > 0)
  .sort((a, b) => b.count - a.count)
  .slice(0, 18);
const maxCount = popularStacks[0]?.count || 1;
---

<Page
  title="StackRigs — An open index of what builders are actually building"
  description="Real stacks, real infrastructure, real experiences. See what developers are building and how."
>
  <!-- Hero -->
  <section class="hero" aria-labelledby="hero-title">
    <h1 id="hero-title">{t('hero.title')}</h1>
    <p class="hero-subtitle">{t('hero.subtitle')}</p>
    <div class="hero-actions">
      <a href={localePath(locale, '/explore')} class="btn btn-primary">{t('hero.cta')}</a>
      <a href={localePath(locale, '/new-build')} class="btn btn-secondary">{t('hero.ctaSecondary')}</a>
    </div>
  </section>

  <!-- Recent Builds -->
  <section class="page-section" aria-labelledby="recent-builds-title">
    <h2 id="recent-builds-title">{t('hero.recentBuilds')}</h2>
    <div class="grid-cards" style="margin-top: var(--space-6);">
      {recentBuilds.map(build => (
        <BuildCard build={build} />
      ))}
    </div>
  </section>

  <!-- Popular Stacks -->
  <section class="page-section" aria-labelledby="popular-stacks-title">
    <h2 id="popular-stacks-title">{t('hero.popularStacks')}</h2>
    <div class="popular-stacks" style="margin-top: var(--space-6);">
      {popularStacks.map((stack, i) => {
        const weight = stack.count / maxCount;
        const tier = i < 3 ? 'top' : i < 8 ? 'mid' : 'base';
        return (
          <a
            href={localePath(locale, `/stack/${stack.slug}`)}
            class={`popular-stack-item popular-stack-item--${tier}`}
            data-astro-prefetch
            style={`--stack-weight: ${weight}`}
          >
            <span class="popular-stack-name">{stack.displayName}</span>
            <span class="popular-stack-count font-mono">{stack.count}</span>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Pi Note -->
  <section class="page-section text-center">
    <a href={localePath(locale, '/infra')} class="pi-note" data-astro-prefetch>
      <span class="freshness-dot freshness-active" aria-hidden="true"></span>
      {t('hero.piNote')}
    </a>
  </section>
</Page>

<style>
  .popular-stacks {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2);
  }

  @media (min-width: 640px) {
    .popular-stacks {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    }
  }

  .popular-stack-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
    border-left: 3px solid transparent;
    transition: border-color var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .popular-stack-item:hover {
    border-left-color: var(--color-accent);
    box-shadow: var(--shadow-card), inset 0 0 0 1px var(--color-border);
  }

  /* Top 3 — biggest, prominent */
  .popular-stack-item--top {
    padding: var(--space-4) var(--space-5);
    background: var(--color-surface-raised);
  }

  .popular-stack-item--top .popular-stack-name {
    font-size: var(--font-size-base);
    font-weight: 600;
  }

  .popular-stack-item--top .popular-stack-count {
    font-size: var(--font-size-sm);
    color: var(--color-accent);
  }

  /* Mid tier */
  .popular-stack-item--mid .popular-stack-name {
    font-weight: 500;
    font-size: var(--font-size-sm);
  }

  .popular-stack-item--mid .popular-stack-count {
    font-size: var(--font-size-xs);
    color: var(--color-text-secondary);
  }

  /* Base tier */
  .popular-stack-item--base .popular-stack-name {
    font-weight: 400;
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  .popular-stack-item--base .popular-stack-count {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  .pi-note {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .pi-note:hover {
    color: var(--color-accent);
  }
</style>
