---
import Page from '../layouts/Page.astro';
import StatusBadge from '../components/StatusBadge.astro';
import { detectLocaleFromPath, useTranslations, localePath } from '../i18n/index';
import { API_BASE } from '../lib/api';

const locale = detectLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
const prefix = locale === 'en' ? '' : `/${locale}`;
---

<Page
  title={`${t('myBuilds.title')} — StackRigs`}
  description="Manage your build logs on StackRigs."
>
  <section class="page-section">
    <div class="my-builds-header">
      <h1>{t('myBuilds.title')}</h1>
      <a href={localePath(locale, '/new-build')} class="btn btn-primary">
        + {t('myBuilds.newBuild')}
      </a>
    </div>

    <div id="my-builds-error" class="signin-error" role="alert" hidden></div>
    <div id="my-builds-loading" class="my-builds-placeholder">
      <div class="skeleton skeleton-title" style="width: 200px;" />
      <div class="skeleton skeleton-line" />
      <div class="skeleton skeleton-line skeleton-line--short" />
    </div>
    <div id="my-builds-list" hidden></div>
    <div id="my-builds-empty" hidden>
      <p class="text-muted">{t('myBuilds.noBuilds')}</p>
      <a href={localePath(locale, '/new-build')} class="btn btn-primary" style="margin-top: var(--space-4);">
        {t('myBuilds.startCta')}
      </a>
    </div>
    <div id="my-builds-auth" hidden>
      <p class="text-muted">{t('myBuilds.loginRequired')}</p>
      <a href={localePath(locale, '/signin')} class="btn btn-primary" style="margin-top: var(--space-4);">
        {t('nav.signIn')}
      </a>
    </div>
  </section>
</Page>

<script define:vars={{
  apiBase: API_BASE,
  prefix,
  labels: {
    edit: t('myBuilds.edit'),
    delete: t('myBuilds.delete'),
    deleteConfirm: t('myBuilds.deleteConfirm'),
    lastUpdated: t('myBuilds.lastUpdated'),
  }
}}>
  document.addEventListener('astro:page-load', async () => {
    const loading = document.getElementById('my-builds-loading');
    const list = document.getElementById('my-builds-list');
    const empty = document.getElementById('my-builds-empty');
    const authDiv = document.getElementById('my-builds-auth');
    const errorDiv = document.getElementById('my-builds-error');
    if (!loading || !list || !empty || !authDiv) return;

    try {
      const meRes = await fetch(`${apiBase}/api/auth/me`, { credentials: 'include' });
      if (!meRes.ok) {
        loading.hidden = true;
        authDiv.hidden = false;
        return;
      }
      const { builder } = await meRes.json();

      const buildsRes = await fetch(`${apiBase}/api/builds?builder=${builder.handle}&limit=100`, { credentials: 'include' });
      const data = buildsRes.ok ? await buildsRes.json() : { data: [] };
      const builds = data.data || [];

      loading.hidden = true;

      if (builds.length === 0) {
        empty.hidden = false;
        return;
      }

      list.hidden = false;
      list.innerHTML = builds.map((b) => `
        <article class="my-build-row card">
          <div class="my-build-row-main">
            <div class="my-build-row-meta">
              <span class="badge badge-${b.status}">${b.status}</span>
              <span class="font-mono text-muted" style="font-size:var(--font-size-xs);">
                ${labels.lastUpdated} ${new Date(b.updated_at).toLocaleDateString()}
              </span>
            </div>
            <h3 class="my-build-row-title">
              <a href="${prefix}/build/${b.id}">${b.name}</a>
            </h3>
            ${b.description ? `<p class="my-build-row-tagline">${b.description}</p>` : ''}
          </div>
          <div class="my-build-row-actions">
            <a href="${prefix}/build/${b.id}/edit" class="btn btn-sm">${labels.edit}</a>
            <button
              class="btn btn-sm btn-danger delete-build-btn"
              data-build-id="${b.id}"
              data-build-name="${b.name.replace(/"/g, '&quot;')}"
            >${labels.delete}</button>
          </div>
        </article>
      `).join('');

      list.querySelectorAll('.delete-build-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const buildId = (btn as HTMLElement).dataset.buildId;
          const buildName = (btn as HTMLElement).dataset.buildName;
          if (!confirm(`${labels.deleteConfirm}\n\n"${buildName}"`)) return;

          const res = await fetch(`${apiBase}/api/builds/${buildId}`, {
            method: 'DELETE',
            credentials: 'include',
          });

          if (res.ok) {
            (btn.closest('.my-build-row') as HTMLElement)?.remove();
            if (list.querySelectorAll('.my-build-row').length === 0) {
              list.hidden = true;
              empty.hidden = false;
            }
          } else {
            if (errorDiv) {
              errorDiv.textContent = 'Delete failed. Please try again.';
              errorDiv.hidden = false;
            }
          }
        });
      });

    } catch {
      if (loading) loading.hidden = true;
      if (errorDiv) {
        errorDiv.textContent = 'Failed to load builds. Please refresh.';
        errorDiv.hidden = false;
      }
    }
  });
</script>

<style>
  .my-builds-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-8);
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .my-builds-placeholder {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 600px;
  }

  .my-build-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-6);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .my-build-row-main {
    flex: 1;
    min-width: 0;
  }

  .my-build-row-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .my-build-row-title {
    font-family: var(--font-display);
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-1);
  }

  .my-build-row-title a {
    color: inherit;
    text-decoration: none;
  }

  .my-build-row-title a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .my-build-row-tagline {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .my-build-row-actions {
    display: flex;
    gap: var(--space-2);
    flex-shrink: 0;
  }

  .btn-danger {
    color: var(--color-accent-red);
    border-color: color-mix(in srgb, var(--color-accent-red) 30%, transparent);
  }

  .btn-danger:hover {
    background: color-mix(in srgb, var(--color-accent-red) 8%, transparent);
  }

  .signin-error {
    padding: var(--space-3) var(--space-4);
    margin-bottom: var(--space-4);
    background: color-mix(in srgb, var(--color-accent-red) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent-red) 30%, transparent);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    color: var(--color-accent-red);
  }
</style>
