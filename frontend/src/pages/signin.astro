---
import Page from '../layouts/Page.astro';
import { detectLocaleFromPath, useTranslations } from '../i18n/index';

const locale = detectLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
const API_BASE = import.meta.env.PUBLIC_API_URL || '';
---

<Page
  title={t('signin.title')}
  description={t('signin.description')}
>
  <section class="signin-page">
    <div class="signin-card card">
      <h1 class="signin-title">{t('signin.heading')}</h1>
      <p class="signin-subtitle text-secondary">{t('signin.subtitle')}</p>

      <div id="signin-error" class="signin-error" role="alert" aria-live="polite" hidden></div>

      <div class="signin-actions">
        <a
          href={`${API_BASE}/api/auth/github`}
          class="btn btn-primary signin-btn"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
          </svg>
          {t('signin.githubButton')}
        </a>

        <div class="signin-divider"><span>o</span></div>

        <button
          class="btn btn-secondary signin-btn"
          id="passkey-signin"
          type="button"
          data-error-start={t('signin.errorPasskeyStart')}
          data-error-failed={t('signin.errorAuthFailed')}
          data-error-unavailable={t('signin.errorNotAvailable')}
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
          </svg>
          {t('signin.passkeyButton')}
        </button>
      </div>

      <p class="signin-note">
        {t('signin.githubButton')} crea tu cuenta automáticamente si es la primera vez.
      </p>
    </div>
  </section>
</Page>

<script>
  const API_BASE = import.meta.env.PUBLIC_API_URL || '';

  document.addEventListener('astro:page-load', () => {
    const passkeyBtn = document.getElementById('passkey-signin') as HTMLButtonElement | null;
    const errorBox = document.getElementById('signin-error') as HTMLElement | null;
    if (!passkeyBtn) return;

    const errorStart = passkeyBtn.dataset.errorStart || 'Could not start passkey authentication.';
    const errorFailed = passkeyBtn.dataset.errorFailed || 'Authentication failed.';
    const errorUnavailable = passkeyBtn.dataset.errorUnavailable || 'Passkey authentication is not available.';

    function showError(msg: string) {
      if (!errorBox) return;
      errorBox.textContent = msg;
      errorBox.hidden = false;
    }

    passkeyBtn.addEventListener('click', async () => {
      if (errorBox) errorBox.hidden = true;
      try {
        const beginRes = await fetch(`${API_BASE}/api/auth/webauthn/login/begin`, {
          method: 'POST',
          credentials: 'include',
        });

        if (!beginRes.ok) {
          showError(errorStart);
          return;
        }

        const options = await beginRes.json();

        const credential = await navigator.credentials.get({
          publicKey: {
            ...options.publicKey,
            challenge: Uint8Array.from(atob(options.publicKey.challenge.replace(/-/g, '+').replace(/_/g, '/')), c => c.charCodeAt(0)),
            allowCredentials: (options.publicKey.allowCredentials || []).map((c: any) => ({
              ...c,
              id: Uint8Array.from(atob(c.id.replace(/-/g, '+').replace(/_/g, '/')), ch => ch.charCodeAt(0)),
            })),
          },
        });

        if (!credential) return;

        const finishRes = await fetch(`${API_BASE}/api/auth/webauthn/login/finish`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(credential),
        });

        if (finishRes.ok) {
          window.location.href = '/';
        } else {
          showError(errorFailed);
        }
      } catch (err) {
        console.error('Passkey auth error:', err);
        showError(errorUnavailable);
      }
    });
  });
</script>

<style>
  .signin-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    padding: var(--space-8);
  }

  .signin-card {
    max-width: 400px;
    width: 100%;
    padding: var(--space-10);
    text-align: center;
  }

  .signin-title {
    font-family: var(--font-display);
    font-size: var(--font-size-2xl);
    margin-bottom: var(--space-2);
  }

  .signin-subtitle {
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-8);
  }

  .signin-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .signin-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    width: 100%;
    padding: var(--space-3) var(--space-4);
    font-size: var(--font-size-sm);
    font-weight: 500;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition:
      box-shadow var(--duration-normal) var(--ease-out),
      transform var(--duration-normal) var(--ease-out);
  }

  .signin-btn:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-hover);
  }

  .signin-error {
    padding: var(--space-3) var(--space-4);
    margin-bottom: var(--space-4);
    background: color-mix(in srgb, var(--color-error, #c0392b) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-error, #c0392b) 30%, transparent);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    color: var(--color-error, #c0392b);
    text-align: left;
  }

  .signin-divider {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-text-muted);
    font-size: var(--font-size-xs);
  }

  .signin-divider::before,
  .signin-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  .signin-note {
    margin-top: var(--space-6);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    line-height: 1.5;
  }
</style>
