---
import Page from '../../layouts/Page.astro';
import { detectLocaleFromPath, useTranslations } from '../../i18n/index';

const locale = detectLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);
const API_BASE = import.meta.env.PUBLIC_API_URL || '';
---

<Page
  title="Iniciar sesion en StackRigs"
  description="Inicia sesion en StackRigs para compartir tu build log."
>
  <section class="signin-page">
    <div class="signin-card card">
      <h1 class="signin-title">Iniciar sesion en StackRigs</h1>
      <p class="signin-subtitle text-secondary">Comparte tu build log con el mundo.</p>

      <div class="signin-actions">
        <button
          class="btn btn-primary signin-btn"
          id="passkey-signin"
          type="button"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
          </svg>
          Iniciar sesion con Passkey
        </button>

        <a
          href={`${API_BASE}/api/auth/github`}
          class="btn btn-secondary signin-btn"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
          </svg>
          Iniciar sesion con GitHub
        </a>
      </div>

      <p class="signin-invite">
        No tienes cuenta? <a href="mailto:hello@stackrigs.com">Solicita una invitacion</a>
      </p>
    </div>
  </section>
</Page>

<script>
  const API_BASE = import.meta.env.PUBLIC_API_URL || '';

  document.addEventListener('astro:page-load', () => {
    const passkeyBtn = document.getElementById('passkey-signin');
    if (!passkeyBtn) return;

    passkeyBtn.addEventListener('click', async () => {
      try {
        const beginRes = await fetch(`${API_BASE}/api/auth/webauthn/login/begin`, {
          method: 'POST',
          credentials: 'include',
        });

        if (!beginRes.ok) {
          alert('No se pudo iniciar la autenticacion con passkey. Intenta de nuevo.');
          return;
        }

        const options = await beginRes.json();

        const credential = await navigator.credentials.get({
          publicKey: {
            ...options.publicKey,
            challenge: Uint8Array.from(atob(options.publicKey.challenge.replace(/-/g, '+').replace(/_/g, '/')), c => c.charCodeAt(0)),
            allowCredentials: (options.publicKey.allowCredentials || []).map((c: any) => ({
              ...c,
              id: Uint8Array.from(atob(c.id.replace(/-/g, '+').replace(/_/g, '/')), ch => ch.charCodeAt(0)),
            })),
          },
        });

        if (!credential) return;

        const finishRes = await fetch(`${API_BASE}/api/auth/webauthn/login/finish`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(credential),
        });

        if (finishRes.ok) {
          window.location.href = '/es/';
        } else {
          alert('La autenticacion fallo. Intenta de nuevo.');
        }
      } catch (err) {
        console.error('Passkey auth error:', err);
        alert('La autenticacion con passkey no esta disponible en este dispositivo.');
      }
    });
  });
</script>

<style>
  .signin-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    padding: var(--space-8);
  }

  .signin-card {
    max-width: 400px;
    width: 100%;
    padding: var(--space-10);
    text-align: center;
  }

  .signin-title {
    font-family: var(--font-display);
    font-size: var(--font-size-2xl);
    margin-bottom: var(--space-2);
  }

  .signin-subtitle {
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-8);
  }

  .signin-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .signin-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    width: 100%;
    padding: var(--space-3) var(--space-4);
    font-size: var(--font-size-sm);
    font-weight: 500;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition:
      box-shadow var(--duration-normal) var(--ease-out),
      transform var(--duration-normal) var(--ease-out);
  }

  .signin-btn:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-hover);
  }

  .signin-invite {
    margin-top: var(--space-8);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  .signin-invite a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .signin-invite a:hover {
    color: var(--color-text);
  }
</style>
