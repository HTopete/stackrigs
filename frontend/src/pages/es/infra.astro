---
import Page from '../../layouts/Page.astro';
import InfraLive from '../../islands/InfraLive';
import UptimeBar from '../../islands/UptimeBar';
import StackTag from '../../components/StackTag.astro';
import { detectLocaleFromPath, useTranslations, localePath } from '../../i18n/index';

const locale = detectLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);

const projectStack = [
  { slug: 'go', displayName: 'Go' },
  { slug: 'astro', displayName: 'Astro' },
  { slug: 'sqlite', displayName: 'SQLite' },
  { slug: 'cloudflare', displayName: 'Cloudflare' },
  { slug: 'docker', displayName: 'Docker' },
];

const infraLabels = {
  uptime: t('infra.uptime'),
  latency: t('infra.latency'),
  requestsPerMinute: t('infra.requestsPerMinute'),
  memoryUsage: t('infra.memoryUsage'),
  loadAvg: t('infra.loadAvg'),
  memTotal: t('infra.memTotal'),
  memAvailable: t('infra.memAvailable'),
  live: t('infra.live'),
  connecting: t('infra.connecting'),
};

const uptimeLabels = {
  title: t('infra.uptimeHistory'),
  daysAgo: t('infra.daysAgo'),
  today: t('infra.today'),
  fullUptime: t('infra.fullUptime'),
  partialOutage: t('infra.partialOutage'),
  noData: t('infra.noData'),
};
---

<Page
  title={`${t('nav.infra')} — StackRigs`}
  description="Metricas en vivo de la infraestructura de StackRigs, corriendo en una Raspberry Pi 5 en Mazatlan, Mexico."
>
  <section class="page-section">
    <h1>{t('nav.infra')}</h1>
    <p class="text-secondary" style="margin-top: var(--space-2); font-size: var(--font-size-lg);">
      {t('infra.hostingNote')}
    </p>
    <div style="margin-top: var(--space-10);">
      <InfraLive client:visible labels={infraLabels} />
    </div>
    <div style="margin-top: var(--space-10);">
      <h2>{t('infra.stack')}</h2>
      <div style="display: flex; flex-wrap: wrap; gap: var(--space-2); margin-top: var(--space-4);">
        {projectStack.map(tech => <StackTag slug={tech.slug} displayName={tech.displayName} />)}
      </div>
    </div>
    <div style="margin-top: var(--space-10);">
      <UptimeBar client:visible labels={uptimeLabels} />
    </div>
  </section>
</Page>
