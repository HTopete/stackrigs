---
import Page from '../layouts/Page.astro';
import InfraLive from '../islands/InfraLive';
import UptimeBar from '../islands/UptimeBar';
import StackTag from '../components/StackTag.astro';
import { detectLocaleFromPath, useTranslations, localePath } from '../i18n/index';

const locale = detectLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);

const projectStack = [
  { slug: 'go', displayName: 'Go' },
  { slug: 'astro', displayName: 'Astro' },
  { slug: 'sqlite', displayName: 'SQLite' },
  { slug: 'cloudflare', displayName: 'Cloudflare' },
  { slug: 'docker', displayName: 'Docker' },
];

const infraLabels = {
  uptime: t('infra.uptime'),
  latency: t('infra.latency'),
  requestsPerMinute: t('infra.requestsPerMinute'),
  memoryUsage: t('infra.memoryUsage'),
  loadAvg: t('infra.loadAvg'),
  memTotal: t('infra.memTotal'),
  memAvailable: t('infra.memAvailable'),
  live: t('infra.live'),
  connecting: t('infra.connecting'),
};

const uptimeLabels = {
  title: t('infra.uptimeHistory'),
  daysAgo: t('infra.daysAgo'),
  today: t('infra.today'),
  fullUptime: t('infra.fullUptime'),
  partialOutage: t('infra.partialOutage'),
  noData: t('infra.noData'),
};
---

<Page
  title={`${t('nav.infra')} — StackRigs`}
  description="Live infrastructure metrics for StackRigs, running on a Raspberry Pi 5 in Mazatlan, Mexico."
>
  <section class="page-section">
    <h1>{t('nav.infra')}</h1>
    <p class="text-secondary" style="margin-top: var(--space-2); font-size: var(--font-size-lg);">
      {t('infra.hostingNote')}
    </p>

    <!-- Live Metrics -->
    <div style="margin-top: var(--space-10);">
      <InfraLive
        client:visible
        labels={infraLabels}
      />
    </div>

    <!-- Project Stack -->
    <div style="margin-top: var(--space-10);">
      <h2>{t('infra.stack')}</h2>
      <div class="infra-stack-tags" style="margin-top: var(--space-4);">
        {projectStack.map(tech => (
          <StackTag slug={tech.slug} displayName={tech.displayName} />
        ))}
      </div>
    </div>

    <!-- Uptime History -->
    <div style="margin-top: var(--space-10);">
      <UptimeBar client:visible labels={uptimeLabels} />
    </div>
  </section>
</Page>

<style>
  .infra-stack-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  :global(.uptime-bar) {
    display: flex;
    gap: 2px;
  }

  :global(.uptime-day) {
    flex: 1;
    height: 32px;
    border-radius: 2px;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  :global(.uptime-day:hover) {
    opacity: 0.8;
  }

  :global(.uptime-day-up) {
    background: var(--color-accent-green);
  }

  :global(.uptime-day-partial) {
    background: var(--color-accent-yellow);
  }

  :global(.uptime-day-down) {
    background: var(--color-accent-red);
  }

  :global(.uptime-day-unknown) {
    background: var(--color-border);
  }

  :global(.uptime-labels) {
    display: flex;
    justify-content: space-between;
    margin-top: var(--space-2);
  }
</style>
