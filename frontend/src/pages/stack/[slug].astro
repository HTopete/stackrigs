---
import Page from '../../layouts/Page.astro';
import BuildCard from '../../components/BuildCard.astro';
import { detectLocaleFromPath, useTranslations, localePath } from '../../i18n/index';
import { API_BASE, getTechnologies } from '../../lib/api';

const { slug } = Astro.params;
const locale = detectLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);

export async function getStaticPaths() {
  const techs = await getTechnologies();
  return techs.map(t => ({ params: { slug: t.slug } }));
}

// Fetch real tech + builds from API
const res = await fetch(`${API_BASE}/api/technologies/${slug}`);
if (!res.ok) return Astro.redirect('/404');

const payload = await res.json();
const tech = payload.technology;
const builds = (payload.builds?.data || []).map((b: any) => ({
  id: String(b.id),
  name: b.name,
  tagline: b.description || undefined,
  status: b.status,
  stack: (b.technologies || []).map((t: any) => ({ slug: t.slug, displayName: t.name })),
  whatWorks: b.what_works || undefined,
  lastUpdated: b.updated_at,
  builderHandle: b.builder?.handle,
  coverImage: b.cover_image || undefined,
}));

const displayName = tech.name || slug;
const buildCount: number = tech.build_count || 0;
const category: string = tech.category || '';
---

<Page
  title={`${displayName} — StackRigs`}
  description={`See how ${buildCount} builders use ${displayName} in production. Real stacks, real experiences.`}
>
  <section class="page-section">
    <header class="stack-header">
      {category && (
        <span class="stack-category font-mono text-muted">{category}</span>
      )}
      <h1>{displayName}</h1>
      <p class="stack-count">
        <strong>{buildCount}</strong> {buildCount === 1 ? t('stack.build') : t('stack.builds')}
      </p>
      <a href={localePath(locale, '/explore')} class="stack-back text-muted">
        ← {t('explore.title')}
      </a>
    </header>

    <!-- Builds Using This Tech -->
    <section aria-labelledby="stack-builds-title">
      <h2 id="stack-builds-title">{t('stack.buildsUsing')} {displayName}</h2>
      <div class="grid-cards" style="margin-top: var(--space-6);">
        {builds.map((build: any) => (
          <BuildCard build={build} />
        ))}
        {builds.length === 0 && (
          <p class="text-muted">{t('explore.noBuilds')}</p>
        )}
      </div>
    </section>
  </section>
</Page>

<style>
  .stack-header {
    margin-bottom: var(--space-10);
  }

  .stack-category {
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: var(--space-2);
  }

  .stack-count {
    margin-top: var(--space-2);
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
  }

  .stack-back {
    display: inline-block;
    margin-top: var(--space-4);
    font-size: var(--font-size-sm);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .stack-back:hover {
    color: var(--color-accent);
  }
</style>
