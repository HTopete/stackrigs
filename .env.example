# StackRigs — Environment Variables
# Copy to .env and fill in real values:  cp .env.example .env

# Server
PORT=8080
ENV=production
BASE_URL=https://api.stackrigs.com

# Database
# Inside Docker this is the container path; the volume maps it to ./data/ on the host.
# SQLite WAL mode is enabled automatically — the .db, .db-wal, and .db-shm files
# all live in the same directory and MUST stay together.
DATABASE_PATH=/data/stackrigs.db

# CORS — allow the frontend (Pages) to call the API (subdomain)
ALLOWED_ORIGINS=https://stackrigs.com,https://api.stackrigs.com

# Auth — WebAuthn (Passkeys)
WEBAUTHN_DISPLAY_NAME=StackRigs
WEBAUTHN_RP_ID=stackrigs.com
WEBAUTHN_RP_ORIGINS=https://stackrigs.com

# Auth — GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://api.stackrigs.com/api/auth/github/callback

# Session
SESSION_SECRET=generate-a-random-32-byte-string

# Cookie domain — share session cookie between frontend and API subdomains
# Use ".stackrigs.com" in production (note the leading dot)
COOKIE_DOMAIN=.stackrigs.com

# Cloudflare Tunnel
TUNNEL_TOKEN=your-cloudflare-tunnel-token

# Cloudflare Pages (frontend)
CF_PAGES_PROJECT=stackrigs
CF_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Backups — Local
BACKUP_RETENTION_DAYS=30

# Backups — Cloudflare R2 remote storage
BACKUP_R2_BUCKET=stackrigs-backups
BACKUP_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
BACKUP_R2_ACCESS_KEY=
BACKUP_R2_SECRET_KEY=
